#!/bin/sh
# .githooks/pre-commit — hard gate for commits made OUTSIDE Claude Code
# (e.g. typed directly in a terminal). Enable once per machine:
#     sh tools/setup.sh
# which runs `git config core.hooksPath .githooks`.
#
# Inside Claude Code the same gate is enforced by hook-pre-commit-guard.sh, so
# this is only the manual-terminal backstop.

ROOT="$(git rev-parse --show-toplevel)" || exit 1
cd "$ROOT" || exit 1
if ! node tools/validate-skills.mjs; then
  echo ""
  echo "✗ Commit blocked: a skill references a tool that doesn't exist (see above)."
  echo "  Fix the tool name, then commit again."
  exit 1
fi
exit 0
